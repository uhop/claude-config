{
  "permissions": {
    "allow": [
      "Bash(vault-curl:*)",
      "Bash(git describe:*)",
      "Bash(git for-each-ref:*)",
      "Bash(git show-ref:*)"
    ],
    "deny": ["Bash(git push:*)", "Bash(git tag:*)", "Bash(npm publish:*)"],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/git-commit-gate.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/destructive-op-gate.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/vault-resume-brief.sh",
            "timeout": 5,
            "statusMessage": "Fetching vault brief"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "autoCompactEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "mcpServers": {
    "vault": {
      "command": "npx",
      "args": ["-y", "@uhop/vault-storage-mcp@latest"],
      "env": {
        "VAULT_API_URL": "${VAULT_API_URL}",
        "VAULT_API_TOKEN": "${VAULT_API_TOKEN}"
      }
    }
  },
  "model": "claude-fable-5[1m]"
}
