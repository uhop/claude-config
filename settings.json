{
  "permissions": {
    "allow": [
      "Bash(vault-curl:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git tag:*)",
      "Bash(npm publish:*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/git-commit-gate.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "autoCompactEnabled": true,
  "skipAutoPermissionPrompt": true,
  "mcpServers": {
    "vault": {
      "command": "npx",
      "args": [
        "-y",
        "@uhop/vault-storage-mcp@latest"
      ],
      "env": {
        "VAULT_API_URL": "${VAULT_API_URL}",
        "VAULT_API_TOKEN": "${VAULT_API_TOKEN}"
      }
    }
  }
}
