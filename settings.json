{
  "permissions": {
    "allow": [
      "Bash(vault-curl:*)"
    ],
    "deny": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git tag:*)",
      "Bash(npm publish:*)"
    ],
    "defaultMode": "auto"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "skipAutoPermissionPrompt": true,
  "mcpServers": {
    "vault": {
      "command": "npx",
      "args": [
        "-y",
        "@uhop/vault-storage-mcp@latest"
      ],
      "env": {
        "VAULT_API_URL": "${VAULT_API_URL}",
        "VAULT_API_TOKEN": "${VAULT_API_TOKEN}"
      }
    }
  }
}
